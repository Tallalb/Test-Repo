<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Dubai Gold Jewelry Price Calculator</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap');
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: #14110d;
    color: #e8e2d5;
    font-family: 'Inter', sans-serif;
  }
  .page { padding: 32px 20px 48px; max-width: 920px; margin: 0 auto; }
  .eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px; letter-spacing: 0.14em; color: #8c7f6a; margin-bottom: 10px;
  }
  h1 {
    font-family: 'Cormorant Garamond', serif; font-weight: 600;
    font-size: clamp(28px, 5vw, 42px); margin: 0 0 10px; color: #ecd9a6; line-height: 1.1;
  }
  .sub { color: #a89e8c; font-size: 15px; line-height: 1.5; max-width: 560px; margin: 0 0 28px; }
  .stamp-row { display: flex; gap: 14px; margin-bottom: 28px; flex-wrap: wrap; }
  .stamp {
    flex: 1 1 120px; border: 1.5px solid #3a332a; border-radius: 50% / 22%;
    padding: 16px 10px; text-align: center; cursor: pointer; background: transparent;
    color: #8c7f6a; transition: all 0.15s ease;
  }
  .stamp.active { border-color: #c8a250; background: rgba(200,162,80,0.10); color: #ecd9a6; }
  .stamp-fineness { font-family: 'IBM Plex Mono', monospace; font-size: 20px; font-weight: 500; letter-spacing: 0.05em; }
  .stamp-label { font-family: 'Cormorant Garamond', serif; font-size: 15px; margin-top: 2px; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 680px) { .grid { grid-template-columns: 1fr; } }
  .panel { background: #1c1712; border: 1px solid #2c261c; border-radius: 10px; padding: 22px; }
  .panel-title {
    font-family: 'Cormorant Garamond', serif; font-size: 20px; color: #c8a250;
    font-weight: 600; margin: 4px 0 14px;
  }
  label { display: block; font-size: 13px; color: #a89e8c; margin-bottom: 14px; }
  input[type=number] {
    width: 100%; margin-top: 6px; padding: 10px 12px; background: #14110d;
    border: 1px solid #3a332a; border-radius: 6px; color: #ecd9a6;
    font-family: 'IBM Plex Mono', monospace; font-size: 15px;
  }
  input:focus, button:focus-visible { outline: 2px solid #c8a250; outline-offset: 2px; }
  .hint { font-size: 12px; color: #6f6455; line-height: 1.5; margin: -8px 0 16px; }
  .toggle-row { display: flex; gap: 8px; margin-bottom: 8px; }
  .toggle-btn {
    flex: 1; padding: 8px 6px; font-size: 12px; background: transparent;
    border: 1px solid #3a332a; border-radius: 6px; color: #8c7f6a; cursor: pointer;
  }
  .toggle-btn.active { border-color: #c8a250; color: #ecd9a6; background: rgba(200,162,80,0.10); }
  .line { display: flex; justify-content: space-between; align-items: baseline; padding: 8px 0; }
  .line .label-text { color: #c7bfae; font-size: 14px; }
  .line .value-text { font-family: 'IBM Plex Mono', monospace; font-size: 15px; color: #e8e2d5; }
  .line.big .label-text { font-size: 16px; }
  .line.big .value-text { font-size: 22px; color: #ecd9a6; font-weight: 600; }
  .line.muted .label-text { color: #8c7f6a; }
  .divider { height: 1px; background: #2c261c; margin: 6px 0; }
  .verdict-box { margin-top: 6px; padding: 16px; background: #14110d; border: 1px solid #2c261c; border-radius: 8px; }
  .verdict-badge {
    display: inline-block; padding: 5px 12px; border-radius: 20px; font-size: 12px;
    font-weight: 600; color: #14110d; margin-bottom: 14px;
  }
  .gauge-wrap { margin-bottom: 14px; }
  .gauge-track { position: relative; height: 8px; background: #2c261c; border-radius: 4px; margin-bottom: 6px; }
  .gauge-zone-ok { position: absolute; left: 0; top: 0; height: 100%; background: rgba(142,168,122,0.25); border-radius: 4px; }
  .gauge-marker { position: absolute; top: -3px; width: 3px; height: 14px; border-radius: 2px; }
  .gauge-labels { display: flex; justify-content: space-between; font-size: 10px; color: #6f6455; font-family: 'IBM Plex Mono', monospace; }
  .verdict-numbers { display: flex; justify-content: space-between; margin-bottom: 14px; gap: 8px; }
  .verdict-num-label { font-size: 11px; color: #6f6455; margin-bottom: 2px; }
  .verdict-num { font-family: 'IBM Plex Mono', monospace; font-size: 15px; color: #e8e2d5; font-weight: 500; }
  .tip { font-size: 13px; color: #a89e8c; line-height: 1.55; }
  footer { margin-top: 32px; font-size: 11px; color: #6f6455; text-align: center; line-height: 1.6; }
</style>
</head>
<body>
<div class="page">
  <div class="eyebrow">DUBAI GOLD SOUK · PRICE CHECK</div>
  <h1>What should this actually cost?</h1>
  <p class="sub">Price it from the metal up — gold weight, making charge, VAT — then see how much room you have to negotiate against the shop's ask.</p>

  <div class="panel" id="livePanel" style="margin-bottom:24px;">
    <div class="panel-title" style="margin-top:0;">Live rate (optional)</div>
    <div class="hint" style="margin-top:-4px;">
      Pulls today's Dubai 18K/22K/24K rates via the Claude API with web search.
      Requires your own Anthropic API key from
      <a href="https://console.anthropic.com" target="_blank" style="color:#c8a250;">console.anthropic.com</a>.
      Each refresh costs a small amount on your API billing. The key is only used in your browser and is never sent anywhere except Anthropic's API.
    </div>
    <label style="margin-bottom:8px;">
      Anthropic API key
      <input type="password" id="apiKeyInput" placeholder="sk-ant-..." />
    </label>
    <label style="display:flex; align-items:center; gap:8px; font-size:12px; margin-bottom:14px;">
      <input type="checkbox" id="rememberKey" style="width:auto; margin:0;" />
      Remember key on this device (stored in local browser storage only)
    </label>
    <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
      <button class="toggle-btn" id="refreshBtn" style="flex:none; padding:8px 16px;">↻ Fetch today's rate</button>
      <span id="liveStatus" style="font-size:12.5px; color:#a89e8c;">Not fetched yet.</span>
    </div>
  </div>

  <div class="stamp-row" id="stampRow"></div>

  <div class="grid">
    <section class="panel">
      <div class="panel-title">Rate & item</div>

      <label id="rateLabel">
        Rate today (AED / gram)
        <input type="number" id="rateInput" step="0.01" />
      </label>
      <div class="hint">Enter today's rate from your jeweller, the Dubai Gold &amp; Jewellery Group fix, or a site like goldpricez.com. Rates move through the day — recheck before you commit.</div>

      <label>
        Item weight (grams)
        <input type="number" id="weightInput" step="0.01" value="10" />
      </label>

      <div class="panel-title">Making charge</div>
      <div class="toggle-row">
        <button class="toggle-btn active" id="btnFlat">AED / gram</button>
        <button class="toggle-btn" id="btnPercent">% of gold value</button>
      </div>
      <input type="number" id="makingInput" step="0.01" value="25" />
      <div class="hint">Typical Dubai making charges: roughly AED 15–40/g for simple machine-made pieces, or 15–30% of gold value for handmade/intricate designs. Branded jewellers charge more.</div>

      <label>
        VAT %
        <input type="number" id="vatInput" step="0.1" value="5" />
      </label>
      <div class="hint">UAE standard VAT on jewellery is 5%.</div>
    </section>

    <section class="panel">
      <div class="panel-title">Fair price breakdown</div>
      <div class="line" id="lineGold"><span class="label-text"></span><span class="value-text"></span></div>
      <div class="line" id="lineMaking"><span class="label-text"></span><span class="value-text"></span></div>
      <div class="line muted" id="lineSubtotal"><span class="label-text">Subtotal</span><span class="value-text"></span></div>
      <div class="line" id="lineVat"><span class="label-text"></span><span class="value-text"></span></div>
      <div class="divider"></div>
      <div class="line big" id="lineFair"><span class="label-text">Fair price</span><span class="value-text"></span></div>

      <div class="panel-title">Shop's ask price</div>
      <label>
        What are they asking? (AED)
        <input type="number" id="askInput" step="0.01" placeholder="e.g. 4200" />
      </label>

      <div class="verdict-box" id="verdictBox" style="display:none;">
        <div class="verdict-badge" id="verdictBadge"></div>
        <div class="gauge-wrap">
          <div class="gauge-track">
            <div class="gauge-zone-ok" id="gaugeZone"></div>
            <div class="gauge-marker" id="gaugeFair" style="background:#8ea87a;"></div>
            <div class="gauge-marker" id="gaugeAsk" style="background:#c05a4a;"></div>
          </div>
          <div class="gauge-labels"><span>0</span><span>fair value → acceptable margin</span><span id="gaugeMax"></span></div>
        </div>
        <div class="verdict-numbers">
          <div><div class="verdict-num-label">Fair price</div><div class="verdict-num" id="numFair"></div></div>
          <div><div class="verdict-num-label">Their ask</div><div class="verdict-num" id="numAsk"></div></div>
          <div><div class="verdict-num-label" id="diffLabel">Markup</div><div class="verdict-num" id="numDiff"></div></div>
        </div>
        <div class="tip" id="tipText"></div>
      </div>
    </section>
  </div>

  <footer>Estimates only — actual invoices may include small municipality or certification fees. Always confirm the day's fixed rate on the receipt before paying.</footer>
</div>

<script>
  const KARATS = [
    { key: "18", label: "18K", fineness: "750", defaultRate: 381.75 },
    { key: "22", label: "22K", fineness: "916", defaultRate: 464.50 },
    { key: "24", label: "24K", fineness: "999", defaultRate: 501.75 },
  ];

  let karat = "18";
  let rates = Object.fromEntries(KARATS.map(k => [k.key, k.defaultRate]));
  let makingType = "flat";

  function aed(n) {
    if (!isFinite(n)) return "—";
    return n.toLocaleString("en-AE", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  // Build karat stamps
  const stampRow = document.getElementById("stampRow");
  function renderStamps() {
    stampRow.innerHTML = "";
    KARATS.forEach(k => {
      const btn = document.createElement("button");
      btn.className = "stamp" + (k.key === karat ? " active" : "");
      btn.innerHTML = `<div class="stamp-fineness">${k.fineness}</div><div class="stamp-label">${k.label}</div>`;
      btn.onclick = () => { karat = k.key; document.getElementById("rateInput").value = rates[karat]; renderStamps(); updateLabels(); calculate(); };
      stampRow.appendChild(btn);
    });
  }

  function updateLabels() {
    const k = KARATS.find(k => k.key === karat);
    document.getElementById("rateLabel").firstChild.textContent = `${k.label} rate today (AED / gram)`;
  }

  const rateInput = document.getElementById("rateInput");
  const weightInput = document.getElementById("weightInput");
  const makingInput = document.getElementById("makingInput");
  const vatInput = document.getElementById("vatInput");
  const askInput = document.getElementById("askInput");
  const btnFlat = document.getElementById("btnFlat");
  const btnPercent = document.getElementById("btnPercent");

  rateInput.value = rates[karat];

  btnFlat.onclick = () => { makingType = "flat"; btnFlat.classList.add("active"); btnPercent.classList.remove("active"); calculate(); };
  btnPercent.onclick = () => { makingType = "percent"; btnPercent.classList.add("active"); btnFlat.classList.remove("active"); calculate(); };

  [rateInput, weightInput, makingInput, vatInput, askInput].forEach(el => el.addEventListener("input", () => {
    rates[karat] = parseFloat(rateInput.value) || 0;
    calculate();
  }));

  function setLine(id, label, value) {
    const el = document.getElementById(id);
    el.querySelector(".label-text").textContent = label;
    el.querySelector(".value-text").textContent = isFinite(value) ? `AED ${aed(value)}` : "—";
  }

  function calculate() {
    const rate = parseFloat(rateInput.value) || 0;
    const w = parseFloat(weightInput.value) || 0;
    const makingVal = parseFloat(makingInput.value) || 0;
    const vat = parseFloat(vatInput.value) || 0;
    const ask = parseFloat(askInput.value) || 0;

    const goldValue = rate * w;
    const making = makingType === "flat" ? makingVal * w : goldValue * (makingVal / 100);
    const subtotal = goldValue + making;
    const vatAmt = subtotal * (vat / 100);
    const fair = subtotal + vatAmt;
    const diff = ask - fair;
    const diffPct = fair > 0 ? (diff / fair) * 100 : 0;
    const ceiling = fair * 1.08;

    setLine("lineGold", `Gold value (${w}g × ${aed(rate)})`, goldValue);
    setLine("lineMaking", `Making charge${makingType === "percent" ? ` (${makingVal}%)` : ""}`, making);
    setLine("lineSubtotal", "Subtotal", subtotal);
    setLine("lineVat", `VAT (${vat}%)`, vatAmt);
    setLine("lineFair", "Fair price", fair);

    const verdictBox = document.getElementById("verdictBox");
    const hasAsk = askInput.value !== "" && !isNaN(ask);

    if (!hasAsk) {
      verdictBox.style.display = "none";
      return;
    }
    verdictBox.style.display = "block";

    let label, color;
    if (diffPct <= 0) { label = "Fair or better"; color = "#8ea87a"; }
    else if (diffPct <= 8) { label = "Within normal margin"; color = "#c8a250"; }
    else if (diffPct <= 20) { label = "Room to negotiate"; color = "#d08a3e"; }
    else { label = "Overpriced — push back"; color = "#c05a4a"; }

    const badge = document.getElementById("verdictBadge");
    badge.textContent = label;
    badge.style.background = color;

    document.getElementById("numFair").textContent = `AED ${aed(fair)}`;
    document.getElementById("numAsk").textContent = `AED ${aed(ask)}`;
    document.getElementById("diffLabel").textContent = diff >= 0 ? "Markup" : "Below fair";
    const numDiff = document.getElementById("numDiff");
    numDiff.textContent = `${diff >= 0 ? "+" : ""}AED ${aed(diff)} (${diffPct >= 0 ? "+" : ""}${diffPct.toFixed(1)}%)`;
    numDiff.style.color = diff > 0 ? "#d08a3e" : "#8ea87a";

    const max = Math.max(fair, ceiling, ask) * 1.15 || 1;
    const pct = v => Math.min(100, (v / max) * 100);
    document.getElementById("gaugeZone").style.width = pct(ceiling) + "%";
    document.getElementById("gaugeFair").style.left = pct(fair) + "%";
    document.getElementById("gaugeAsk").style.left = pct(ask) + "%";
    document.getElementById("gaugeMax").textContent = aed(max);

    let tip;
    if (diffPct <= 0) tip = "This is at or below the calculated fair price. No real bargaining room left — a fine price to accept.";
    else if (diffPct <= 8) tip = "This sits inside normal retail margin. Light negotiation might shave a little off, but don't expect much movement.";
    else if (diffPct <= 20) tip = `Open by offering close to the fair price (around AED ${aed(fair)}), and expect to settle somewhere near AED ${aed(ceiling)}. Mention you've priced the gold weight and making charge yourself — it signals you won't overpay.`;
    else tip = `The gap is large enough to push hard. Anchor low, near AED ${aed(fair)}, and be willing to walk — in the Gold Souk there's almost always a shop next door with the same design.`;
    document.getElementById("tipText").textContent = tip;
  }

  // --- Live rate via Anthropic API ---
  const apiKeyInput = document.getElementById("apiKeyInput");
  const rememberKey = document.getElementById("rememberKey");
  const refreshBtn = document.getElementById("refreshBtn");
  const liveStatus = document.getElementById("liveStatus");

  const savedKey = localStorage.getItem("gold_calc_api_key");
  if (savedKey) {
    apiKeyInput.value = savedKey;
    rememberKey.checked = true;
  }

  rememberKey.addEventListener("change", () => {
    if (!rememberKey.checked) localStorage.removeItem("gold_calc_api_key");
    else if (apiKeyInput.value) localStorage.setItem("gold_calc_api_key", apiKeyInput.value);
  });
  apiKeyInput.addEventListener("input", () => {
    if (rememberKey.checked) localStorage.setItem("gold_calc_api_key", apiKeyInput.value);
  });

  async function fetchLiveRates() {
    const key = apiKeyInput.value.trim();
    if (!key) {
      liveStatus.textContent = "Enter your Anthropic API key first.";
      liveStatus.style.color = "#c05a4a";
      return;
    }
    refreshBtn.disabled = true;
    liveStatus.textContent = "Fetching today's Dubai gold rate…";
    liveStatus.style.color = "#c8a250";

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "x-api-key": key,
          "anthropic-version": "2023-06-01",
          "anthropic-dangerous-direct-browser-access": "true",
        },
        body: JSON.stringify({
          model: "claude-sonnet-4-6",
          max_tokens: 1000,
          messages: [
            {
              role: "user",
              content:
                "Search the web for today's Dubai gold price per gram in AED for 18K, 22K, and 24K gold (retail rate, e.g. from Dubai Gold & Jewellery Group, Goodreturns, or goldpricez.com). " +
                "Respond with ONLY a raw JSON object, no markdown fences, no commentary, in exactly this shape: " +
                '{"date":"<date>","k18":<number>,"k22":<number>,"k24":<number>,"source":"<short source name>"}',
            },
          ],
          tools: [{ type: "web_search_20250305", name: "web_search" }],
        }),
      });

      if (!response.ok) {
        const bodyText = await response.text().catch(() => "");
        throw new Error(`API error ${response.status}: ${bodyText.slice(0, 200)}`);
      }

      const data = await response.json();
      const textResponses = (data.content || [])
        .filter(item => item.type === "text")
        .map(item => item.text)
        .join("\n");
      const cleaned = textResponses.replace(/```json|```/g, "").trim();
      const jsonMatch = cleaned.match(/\{[\s\S]*\}/);
      if (!jsonMatch) throw new Error("Could not parse a rate from the response");

      const parsed = JSON.parse(jsonMatch[0]);
      if (!parsed.k18 || !parsed.k22 || !parsed.k24) throw new Error("Response missing rate fields");

      rates["18"] = parseFloat(parsed.k18);
      rates["22"] = parseFloat(parsed.k22);
      rates["24"] = parseFloat(parsed.k24);
      rateInput.value = rates[karat];

      liveStatus.textContent = `Updated for ${parsed.date || "today"} · via ${parsed.source || "web search"}`;
      liveStatus.style.color = "#8ea87a";
      calculate();
    } catch (err) {
      console.error("Live rate fetch failed:", err);
      const msg = err && err.message ? err.message : "unknown error";
      liveStatus.textContent = msg.includes("Failed to fetch")
        ? "Network/CORS error reaching the API. Check your connection and key."
        : `Fetch failed: ${msg}`;
      liveStatus.style.color = "#c05a4a";
    } finally {
      refreshBtn.disabled = false;
    }
  }

  refreshBtn.addEventListener("click", fetchLiveRates);

  renderStamps();
  updateLabels();
  calculate();
</script>
</body>
</html>
